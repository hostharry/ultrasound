    "\n",
    "# Step 4: Define gradient and divergence operators for ADMM\n",
    "# The divergence operator must be the negative adjoint of gradient for convergence\n",
    "\n",
    "def gradient_op(x, shape):\n",
    "    \"\"\"\n",
    "    Compute gradient of image x\n",
    "    Returns gradient as a stacked vector [gx; gy]\n",
    "    \"\"\"\n",
    "    x_img = x.reshape(shape)\n",
    "    # Forward differences with periodic boundary conditions\n",
    "    gx = np.roll(x_img, -1, axis=1) - x_img\n",
    "    gy = np.roll(x_img, -1, axis=0) - x_img\n",
    "    return np.concatenate([gx.flatten(), gy.flatten()])\n",
    "\n",
    "def divergence_op(g, shape):\n",
    "    \"\"\"\n",
    "    Compute divergence (negative adjoint of gradient)\n",
    "    Input g is a stacked vector [gx; gy]\n",
    "    \"\"\"\n",
    "    n_pixels = shape[0] * shape[1]\n",
    "    gx = g[:n_pixels].reshape(shape)\n",
    "    gy = g[n_pixels:].reshape(shape)\n",
    "    \n",
    "    # Backward differences (adjoint of forward differences)\n",
    "    # div = -grad^T, so we need negative of the transpose operation\n",
    "    div_x = gx - np.roll(gx, 1, axis=1)\n",
    "    div_y = gy - np.roll(gy, 1, axis=0)\n",
    "    \n",
    "    return -(div_x + div_y).flatten()\n",
    "\n",
    "# Test adjoint relationship\n",
    "print(\"Testing gradient-divergence adjoint relationship...\")\n",
    "test_x = np.random.randn(N)\n",
    "test_g = np.random.randn(2*N)\n",
    "grad_x = gradient_op(test_x, img_shape)\n",
    "div_g = divergence_op(test_g, img_shape)\n",
    "\n",
    "# Check <grad(x), g> = <x, div(g)>\n",
    "inner1 = np.dot(grad_x, test_g)\n",
    "inner2 = np.dot(test_x, div_g)\n",
    "print(f\"<grad(x), g> = {inner1:.6f}\")\n",
    "print(f\"<x, div(g)> = {inner2:.6f}\")\n",
    "print(f\"Relative difference: {abs(inner1 - inner2) / abs(inner1):.2e}\")\n"
   ]
