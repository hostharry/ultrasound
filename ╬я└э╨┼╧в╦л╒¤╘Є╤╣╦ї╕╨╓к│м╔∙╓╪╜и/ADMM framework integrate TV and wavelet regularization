    "# Step 6: Define soft-thresholding operator for ADMM updates\n",
    "\n",
    "def soft_threshold(x, threshold):\n",
    "    \"\"\"\n",
    "    Soft thresholding operator for L1 regularization\n",
    "    Applies element-wise: sign(x) * max(|x| - threshold, 0)\n",
    "    \"\"\"\n",
    "    return np.sign(x) * np.maximum(np.abs(x) - threshold, 0)\n",
    "\n",
    "# Test soft thresholding\n",
    "test_vals = np.array([-2, -1, -0.5, 0, 0.5, 1, 2])\n",
    "threshold_test = 0.7\n",
    "result = soft_threshold(test_vals, threshold_test)\n",
    "print(\"Testing soft thresholding operator:\")\n",
    "print(f\"Input: {test_vals}\")\n",
    "print(f\"Threshold: {threshold_test}\")\n",
    "print(f\"Output: {result}\")\n"
