   "source": [
    "\n",
    "# Step 7: Implement the dual-regularizer ADMM solver\n",
    "# Optimization problem: argmin(x) 0.5*||Ax-y||^2 + ||W_tv*grad(x)||_1 + ||W_wav*Psi(x)||_1\n",
    "\n",
    "def dual_admm_solver(A, y, img_shape, W_tv, W_wav, \n",
    "                     lambda_tv=0.01, lambda_wav=0.01,\n",
    "                     rho1=0.1, rho2=0.1,\n",
    "                     max_iter=100, tol=1e-4, verbose=True):\n",
    "    \"\"\"\n",
    "    Dual-regularizer ADMM solver for compressed sensing with TV and Wavelet regularization\n",
    "    \n",
    "    Parameters:\n",
    "    - A: Measurement matrix (M x N)\n",
    "    - y: Measurements (M,)\n",
    "    - img_shape: Shape of image (h, w)\n",
    "    - W_tv: TV weight map (h, w)\n",
    "    - W_wav: Wavelet weight map (h, w)\n",
    "    - lambda_tv: TV regularization parameter\n",
    "    - lambda_wav: Wavelet regularization parameter\n",
    "    - rho1: ADMM penalty parameter for TV\n",
    "    - rho2: ADMM penalty parameter for wavelets\n",
    "    - max_iter: Maximum iterations\n",
    "    - tol: Convergence tolerance\n",
    "    - verbose: Print progress\n",
    "    \n",
    "    Returns:\n",
    "    - x: Reconstructed image (flattened)\n",
    "    - obj_history: Objective function values\n",
    "    \"\"\"\n",
    "    N = img_shape[0] * img_shape[1]\n",
    "    M = A.shape[0]\n",
    "    \n",
    "    # Initialize variables\n",
    "    x = np.zeros(N)\n",
    "    \n",
    "    # Get initial wavelet coefficient structure\n",
    "    _, coeff_slices, coeff_shape = wavelet_forward(x, img_shape, wavelet=wavelet_name, level=wavelet_level)\n",
    "    n_coeffs = coeff_shape[0] * coeff_shape[1]\n",
    "    \n",
    "    # Auxiliary variables\n",
    "    z1 = np.zeros(2 * N)  # Gradient (stacked [gx; gy])\n",
    "    z2 = np.zeros(n_coeffs)  # Wavelet coefficients\n",
    "    \n",
    "    # Dual variables (Lagrange multipliers)\n",
    "    u1 = np.zeros(2 * N)\n",
    "    u2 = np.zeros(n_coeffs)\n",
    "    \n",
    "    # Precompute A^T @ A and A^T @ y\n",
    "    AtA = A.T @ A\n",
    "    Aty = A.T @ y\n",
    "    \n",
    "    # Objective function history\n",
    "    obj_history = []\n",
    "    \n",
    "    # ADMM iterations\n",
    "    for iter_num in range(max_iter):\n",
    "        # --- x-update: Solve linear system ---\n",
    "        # (A^T*A + rho1*divgrad + rho2*Psi^T*Psi)*x = A^T*y + rho1*div(z1-u1) + rho2*Psi^T(z2-u2)\n",
    "        \n",
    "        # Right-hand side\n",
    "        rhs = Aty.copy()\n",
    "        rhs += rho1 * divergence_op(z1 - u1, img_shape)\n",
    "        \n",
    "        # For wavelet term: Psi^T(z2-u2) = inverse wavelet transform\n",
    "        wav_term = wavelet_inverse(z2 - u2, coeff_shape, coeff_slices, wavelet=wavelet_name, level=wavelet_level)\n",
    "        rhs += rho2 * wav_term[:N]\n",
    "        \n",
    "        # Define linear operator for CG\n",
    "        def matvec(v):\n",
    "            result = AtA @ v\n",
    "            result += rho1 * divergence_op(gradient_op(v, img_shape), img_shape)\n",
    "            \n",
    "            # For Psi^T*Psi: forward then inverse wavelet transform\n",
    "            wav_v, _, _ = wavelet_forward(v, img_shape, wavelet=wavelet_name, level=wavelet_level)\n",
    "            wav_back = wavelet_inverse(wav_v, coeff_shape, coeff_slices, wavelet=wavelet_name, level=wavelet_level)\n",
    "            result += rho2 * wav_back[:N]\n",
    "            \n",
    "            return result\n",
    "        \n",
    "        A_op = LinearOperator((N, N), matvec=matvec)\n",
    "        # scipy.sparse.linalg.cg accepts only maxiter, not tol\n",
    "        x, info = cg(A_op, rhs, x0=x, maxiter=50)\n",
    "        \n",
    "        if info != 0:\n",
    "            print(f\"Warning: CG did not converge at iteration {iter_num}, info={info}\")\n",
    "        \n",
    "        # --- z1-update (TV): Weighted soft thresholding on gradient ---\n",
    "        grad_x = gradient_op(x, img_shape)\n",
    "        v1 = grad_x + u1\n",
    "        \n",
    "        # Apply spatially-varying weights\n",
    "        # Split into gx and gy components\n",
    "        gx_part = v1[:N].reshape(img_shape)\n",
    "        gy_part = v1[N:].reshape(img_shape)\n",
    "        \n",
    "        # Weighted soft thresholding\n",
    "        threshold_tv = (lambda_tv * W_tv) / rho1\n",
    "        gx_thresh = soft_threshold(gx_part, threshold_tv)\n",
    "        gy_thresh = soft_threshold(gy_part, threshold_tv)\n",
    "        \n",
    "        z1 = np.concatenate([gx_thresh.flatten(), gy_thresh.flatten()])\n",
    "        \n",
    "        # --- z2-update (Wavelet): Weighted soft thresholding on wavelet coefficients ---\n",
    "        psi_x, _, _ = wavelet_forward(x, img_shape, wavelet=wavelet_name, level=wavelet_level)\n",
    "        v2 = psi_x + u2\n",
    "        \n",
    "        # Apply spatially-varying weights (map weight map to wavelet domain)\n",
    "        # For simplicity, reshape weight map to match coefficient shape and flatten\n",
    "        W_wav_resized = np.array(Image.fromarray(W_wav).resize(coeff_shape[::-1], Image.BILINEAR))\n",
    "        W_wav_flat = W_wav_resized.flatten()\n",
    "        \n",
    "        threshold_wav = (lambda_wav * W_wav_flat) / rho2\n",
    "        z2 = soft_threshold(v2, threshold_wav)\n",
    "        \n",
    "        # --- u1-update (dual variable for TV) ---\n",
    "        u1 = u1 + grad_x - z1\n",
    "        \n",
    "        # --- u2-update (dual variable for wavelets) ---\n",
    "        u2 = u2 + psi_x - z2\n",
    "        \n",
    "        # --- Compute objective function ---\n",
    "        residual = A @ x - y\n",
    "        data_fidelity = 0.5 * np.sum(residual ** 2)\n",
    "        \n",
    "        # TV term\n",
    "        grad_x_img = grad_x[:N].reshape(img_shape)\n",
    "        grad_y_img = grad_x[N:].reshape(img_shape)\n",
    "        grad_mag = np.sqrt(grad_x_img**2 + grad_y_img**2)\n",
    "        tv_term = lambda_tv * np.sum(W_tv * grad_mag)\n",
    "        \n",
    "        # Wavelet term\n",
    "        wav_term = lambda_wav * np.sum(W_wav_flat * np.abs(psi_x))\n",
    "        \n",
    "        objective = data_fidelity + tv_term + wav_term\n",
    "        obj_history.append(objective)\n",
    "        \n",
    "        if verbose and iter_num % 10 == 0:\n",
    "            print(f\"Iter {iter_num:3d}: Obj = {objective:.6f}, Data = {data_fidelity:.6f}, TV = {tv_term:.6f}, Wav = {wav_term:.6f}\")\n",
    "        \n",
    "        # Check convergence\n",
    "        if iter_num > 0 and abs(obj_history[-1] - obj_history[-2]) / obj_history[-2] < tol:\n",
    "            print(f\"Converged at iteration {iter_num}\")\n",
    "            break\n",
    "    \n",
    "    return x, obj_history\n",
    "\n",
    "print(\"Dual-regularizer ADMM solver defined\")\n"
   ]
