    "\n",
    "# Step 3: Create spatially-varying weight maps for TV (from gradients) and wavelets (from entropy)\n",
    "# These maps are derived from the ground-truth image to simulate \"oracle\" weights\n",
    "\n",
    "# TV weight map: Based on gradient magnitude of ground truth\n",
    "# Higher gradients -> higher TV weights (preserve edges by applying stronger regularization)\n",
    "gx = np.gradient(img_array, axis=1)\n",
    "gy = np.gradient(img_array, axis=0)\n",
    "grad_mag = np.sqrt(gx**2 + gy**2)\n",
    "\n",
    "# Normalize and create weight map (add small epsilon to avoid division by zero)\n",
    "W_tv = grad_mag / (grad_mag.max() + 1e-8)\n",
    "W_tv = W_tv + 0.1  # Add baseline weight to avoid zero weights\n",
    "W_tv = W_tv / W_tv.mean()  # Normalize to mean 1\n",
    "\n",
    "print(f\"TV weight map shape: {W_tv.shape}\")\n",
    "print(f\"TV weight range: [{W_tv.min():.3f}, {W_tv.max():.3f}], mean: {W_tv.mean():.3f}\")\n",
    "\n",
    "# Wavelet weight map: Based on local entropy\n",
    "# Higher entropy -> higher wavelet weights\n",
    "def local_entropy(img, window_size=5):\n",
    "    \"\"\"Calculate local entropy using a sliding window\"\"\"\n",
    "    from scipy.stats import entropy as shannon_entropy\n",
    "    \n",
    "    def window_entropy(window):\n",
    "        # Compute histogram and entropy\n",
    "        hist, _ = np.histogram(window, bins=10, range=(0, 1))\n",
    "        hist = hist / hist.sum()\n",
    "        return shannon_entropy(hist + 1e-10)\n",
    "    \n",
    "    return generic_filter(img, window_entropy, size=window_size)\n",
    "\n",
    "W_wav = local_entropy(img_array, window_size=5)\n",
    "W_wav = W_wav / (W_wav.max() + 1e-8)\n",
    "W_wav = W_wav + 0.1  # Add baseline weight\n",
    "W_wav = W_wav / W_wav.mean()  # Normalize to mean 1\n",
    "\n",
    "print(f\"Wavelet weight map shape: {W_wav.shape}\")\n",
    "print(f\"Wavelet weight range: [{W_wav.min():.3f}, {W_wav.max():.3f}], mean: {W_wav.mean():.3f}\")\n"
