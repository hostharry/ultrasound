    "# Step 5: Define wavelet transform operators\n",
    "# Using 2D discrete wavelet transform (DWT) from PyWavelets\n",
    "\n",
    "def wavelet_forward(x, shape, wavelet='db4', level=3):\n",
    "    \"\"\"\n",
    "    Apply 2D wavelet transform to image x\n",
    "    Returns coefficients as a flattened vector\n",
    "    \"\"\"\n",
    "    x_img = x.reshape(shape)\n",
    "    coeffs = pywt.wavedec2(x_img, wavelet=wavelet, level=level)\n",
    "    \n",
    "    # Flatten coefficients into a single vector\n",
    "    coeff_arr, coeff_slices = pywt.coeffs_to_array(coeffs)\n",
    "    return coeff_arr.flatten(), coeff_slices, coeff_arr.shape\n",
    "\n",
    "def wavelet_inverse(c, coeff_shape, coeff_slices, wavelet='db4', level=3):\n",
    "    \"\"\"\n",
    "    Apply inverse 2D wavelet transform\n",
    "    Returns reconstructed image as a flattened vector\n",
    "    \"\"\"\n",
    "    # Reconstruct coefficient structure\n",
    "    coeff_arr = c.reshape(coeff_shape)\n",
    "    coeffs = pywt.array_to_coeffs(coeff_arr, coeff_slices, output_format='wavedec2')\n",
    "    \n",
    "    # Inverse transform\n",
    "    x_img = pywt.waverec2(coeffs, wavelet=wavelet)\n",
    "    return x_img.flatten()\n",
