    "    img = img.resize(target_size, Image.BILINEAR)\n",
    "    img_array = np.array(img, dtype=np.float64) / 255.0  # Normalize to [0, 1]\n",
    "    \n",
    "    # Load mask\n",
    "    mask = Image.open(mask_path).convert('L')\n",
    "    mask = mask.resize(target_size, Image.NEAREST)\n",
    "    mask_array = (np.array(mask) > 0).astype(bool)  # Binary mask\n",
    "    \n",
    "    return img_array, mask_array\n",
    "\n",
    "# Load all 30 images and their masks\n",
    "all_images = []\n",
    "all_masks = []\n",
    "all_names = []\n",
    "all_labels = []\n",
    "\n",
    "base_path = 'Dataset_BUSI_with_GT'\n",
    "\n",
    "# Load benign images\n",
    "for img_name in benign_images:\n",
    "    img_path = os.path.join(base_path, 'benign', f'{img_name}.png')\n",
    "    mask_path = os.path.join(base_path, 'benign', f'{img_name}_mask.png')\n",
    "    \n",
    "    if os.path.exists(img_path) and os.path.exists(mask_path):\n",
