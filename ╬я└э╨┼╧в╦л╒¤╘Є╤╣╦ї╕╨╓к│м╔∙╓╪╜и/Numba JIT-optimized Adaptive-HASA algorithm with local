    "\n",
    "# Step 5: Implement Adaptive-HASA reconstruction algorithm\n",
    "from skimage.restoration import denoise_tv_chambolle\n",
    "\n",
    "def adaptive_hasa_reconstruction(y, A, window_size=9, n_iterations=50, step_size=0.001, \n",
    "                                   tv_weight_base=0.1, wavelet_weight_base=0.1):\n",
    "    \"\"\"\n",
    "    Adaptive Hybrid Algorithm for Sparse Acquisition (Adaptive-HASA)\n",
    "    \n",
    "    Parameters:\n",
    "    - y: measurement vector\n",
    "    - A: measurement matrix\n",
    "    - window_size: size of window for local statistics (5, 9, or 15)\n",
    "    - n_iterations: number of iterations\n",
    "    - step_size: gradient descent step size\n",
    "    - tv_weight_base: base weight for TV denoising\n",
    "    - wavelet_weight_base: base weight for wavelet thresholding\n",
    "    \n",
    "    Returns:\n",
    "    - reconstructed image (256x256)\n",
    "    \"\"\"\n",
    "    # Initialize with A^T * y (backprojection)\n",
    "    x = A.T @ y\n",
    "    x = x.reshape(256, 256)\n",
    "    x = np.clip(x, 0, 1)\n",
    "    \n",
    "    for iteration in range(n_iterations):\n",
    "        # Compute local statistics using Numba-optimized functions\n",
    "        entropy_map = compute_local_entropy_numba(x, window_size)\n",
    "        gradient_map = compute_local_gradient_numba(x, window_size)\n",
    "        \n",
    "        # Normalize maps to [0, 1]\n",
    "        if entropy_map.max() > 0:\n",
    "            entropy_map = entropy_map / entropy_map.max()\n",
    "        if gradient_map.max() > 0:\n",
    "            gradient_map = gradient_map / gradient_map.max()\n",
    "        \n",
    "        # Compute adaptive weights\n",
    "        # Higher gradient -> higher TV weight\n",
    "        # Higher entropy -> higher wavelet weight\n",
    "        tv_weight = tv_weight_base * (1 + gradient_map)\n",
    "        wavelet_weight = wavelet_weight_base * (1 + entropy_map)\n",
    "        \n",
    "        # Data fidelity gradient step\n",
    "        x_flat = x.flatten()\n",
    "        residual = A @ x_flat - y\n",
    "        gradient = A.T @ residual\n",
    "        x_flat = x_flat - step_size * gradient\n",
    "        x = x_flat.reshape(256, 256)\n",
    "        x = np.clip(x, 0, 1)\n",
    "        \n",
    "        # Sequential application: TV denoising followed by wavelet thresholding\n",
    "        # (reversing the order degrades quality as noted in dataset description)\n",
    "        \n",
    "        # 1. TV denoising with spatially adaptive weights\n",
    "        # Use mean TV weight for this iteration\n",
    "        tv_weight_mean = np.mean(tv_weight)\n",
    "        x_tv = denoise_tv_chambolle(x, weight=tv_weight_mean)\n",
    "        \n",
    "        # 2. Wavelet thresholding with spatially adaptive weights\n",
    "        # Decompose\n",
    "        coeffs = pywt.dwt2(x_tv, 'db1')\n",
    "        cA, (cH, cV, cD) = coeffs\n",
    "        \n",
    "        # Compute adaptive thresholds based on mean wavelet weight\n",
    "        wavelet_weight_mean = np.mean(wavelet_weight)\n",
    "        threshold = wavelet_weight_mean * 0.1  # Scaling factor for threshold\n",
    "        \n",
    "        # Apply soft thresholding\n",
    "        cH = pywt.threshold(cH, threshold, mode='soft')\n",
    "        cV = pywt.threshold(cV, threshold, mode='soft')\n",
    "        cD = pywt.threshold(cD, threshold, mode='soft')\n",
    "        \n",
    "        # Reconstruct\n",
    "        x = pywt.idwt2((cA, (cH, cV, cD)), 'db1')\n",
    "        x = np.clip(x, 0, 1)\n",
    "    \n",
    "    return x\n",
    "\n",
    "print(\"Adaptive-HASA reconstruction algorithm defined\")\n",
    "print(\"  Parameters: window_size, n_iterations, step_size, tv_weight_base, wavelet_weight_base\")\n"
   ]
