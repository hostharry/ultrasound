    "\n",
    "# Step 6: Define metrics calculation functions\n",
    "def calculate_metrics(original, reconstructed, mask):\n",
    "    \"\"\"\n",
    "    Calculate comprehensive metrics for reconstruction quality.\n",
    "    \n",
    "    Parameters:\n",
    "    - original: original image (256x256)\n",
    "    - reconstructed: reconstructed image (256x256)\n",
    "    - mask: binary mask for tumor ROI (256x256)\n",
    "    \n",
    "    Returns:\n",
    "    - dict with metrics: full_psnr, full_ssim, tumor_psnr, tumor_ssim, bg_psnr, bg_ssim\n",
    "    \"\"\"\n",
    "    # Ensure values are in valid range\n",
    "    original = np.clip(original, 0, 1)\n",
    "    reconstructed = np.clip(reconstructed, 0, 1)\n",
    "    \n",
    "    # Full image metrics\n",
    "    full_psnr = psnr(original, reconstructed, data_range=1.0)\n",
    "    full_ssim = ssim(original, reconstructed, data_range=1.0)\n",
    "    \n",
    "    # Tumor ROI metrics (if tumor exists)\n",
    "    tumor_pixels = np.sum(mask)\n",
    "    if tumor_pixels > 49:  # Minimum size for reliable SSIM\n",
    "        tumor_roi_orig = original[mask]\n",
    "        tumor_roi_recon = reconstructed[mask]\n",
    "        tumor_psnr = psnr(tumor_roi_orig, tumor_roi_recon, data_range=1.0)\n",
    "        \n",
    "        # For SSIM, we need 2D image, so use bounding box approach\n",
    "        rows, cols = np.where(mask)\n",
    "        r_min, r_max = rows.min(), rows.max() + 1\n",
    "        c_min, c_max = cols.min(), cols.max() + 1\n",
    "        tumor_roi_orig_2d = original[r_min:r_max, c_min:c_max]\n",
    "        tumor_roi_recon_2d = reconstructed[r_min:r_max, c_min:c_max]\n",
    "        \n",
    "        if tumor_roi_orig_2d.shape[0] >= 7 and tumor_roi_orig_2d.shape[1] >= 7:\n",
    "            tumor_ssim = ssim(tumor_roi_orig_2d, tumor_roi_recon_2d, data_range=1.0)\n",
    "        else:\n",
    "            tumor_ssim = np.nan\n",
    "    else:\n",
    "        tumor_psnr = np.nan\n",
    "        tumor_ssim = np.nan\n",
    "    \n",
    "    # Background metrics (inverse of mask)\n",
    "    bg_mask = ~mask\n",
    "    bg_pixels = np.sum(bg_mask)\n",
    "    if bg_pixels > 49:\n",
    "        bg_orig = original[bg_mask]\n",
    "        bg_recon = reconstructed[bg_mask]\n",
    "        bg_psnr = psnr(bg_orig, bg_recon, data_range=1.0)\n",
    "        \n",
    "        # For background SSIM, use full image with masked tumor region\n",
    "        bg_orig_2d = original.copy()\n",
    "        bg_orig_2d[mask] = 0\n",
    "        bg_recon_2d = reconstructed.copy()\n",
    "        bg_recon_2d[mask] = 0\n",
    "        bg_ssim = ssim(bg_orig_2d, bg_recon_2d, data_range=1.0)\n",
    "    else:\n",
    "        bg_psnr = np.nan\n",
    "        bg_ssim = np.nan\n",
    "    \n",
    "    return {\n",
    "        'full_psnr': full_psnr,\n",
    "        'full_ssim': full_ssim,\n",
    "        'tumor_psnr': tumor_psnr,\n",
    "        'tumor_ssim': tumor_ssim,\n",
    "        'bg_psnr': bg_psnr,\n",
    "        'bg_ssim': bg_ssim\n",
    "    }\n",
    "\n",
    "print(\"Metrics calculation function defined\")\n",
    "print(\"  Metrics: full_psnr, full_ssim, tumor_psnr, tumor_ssim, bg_psnr, bg_ssim\")\n"
   ]
