    "\n",
    "# Step 4: Implement Numba JIT-optimized local entropy calculation\n",
    "import pywt\n",
    "\n",
    "@jit(nopython=True)\n",
    "def compute_local_entropy_numba(image, window_size):\n",
    "    \"\"\"\n",
    "    Compute local entropy using Numba JIT for massive speedup.\n",
    "    This replaces the extremely slow scipy.ndimage.generic_filter approach.\n",
    "    \"\"\"\n",
    "    h, w = image.shape\n",
    "    entropy_map = np.zeros_like(image)\n",
    "    half_window = window_size // 2\n",
    "    \n",
    "    for i in range(h):\n",
    "        for j in range(w):\n",
    "            # Define window boundaries with edge handling\n",
    "            i_min = max(0, i - half_window)\n",
    "            i_max = min(h, i + half_window + 1)\n",
    "            j_min = max(0, j - half_window)\n",
    "            j_max = min(w, j + half_window + 1)\n",
    "            \n",
    "            # Extract local window\n",
    "            window = image[i_min:i_max, j_min:j_max]\n",
    "            \n",
    "            # Compute histogram and entropy\n",
    "            # Bin values into 256 bins for [0, 1] range\n",
    "            hist = np.zeros(256, dtype=np.int64)\n",
    "            window_flat = window.flatten()\n",
    "            for val in window_flat:\n",
    "                bin_idx = min(int(val * 255), 255)\n",
    "                hist[bin_idx] += 1\n",
    "            \n",
    "            # Compute entropy\n",
    "            total = window_flat.size\n",
    "            entropy = 0.0\n",
    "            for count in hist:\n",
    "                if count > 0:\n",
    "                    p = count / total\n",
    "                    entropy -= p * np.log2(p)\n",
    "            \n",
    "            entropy_map[i, j] = entropy\n",
    "    \n",
    "    return entropy_map\n",
    "\n",
    "@jit(nopython=True)\n",
    "def compute_local_gradient_numba(image, window_size):\n",
    "    \"\"\"\n",
    "    Compute local gradient magnitude using Numba JIT.\n",
    "    \"\"\"\n",
    "    h, w = image.shape\n",
    "    gradient_map = np.zeros_like(image)\n",
    "    half_window = window_size // 2\n",
    "    \n",
    "    for i in range(h):\n",
    "        for j in range(w):\n",
    "            # Define window boundaries with edge handling\n",
    "            i_min = max(0, i - half_window)\n",
    "            i_max = min(h, i + half_window + 1)\n",
    "            j_min = max(0, j - half_window)\n",
    "            j_max = min(w, j + half_window + 1)\n",
    "            \n",
    "            # Extract local window\n",
    "            window = image[i_min:i_max, j_min:j_max]\n",
    "            \n",
    "            # Compute gradient magnitude (simple approximation)\n",
    "            grad_sum = 0.0\n",
    "            count = 0\n",
    "            wh, ww = window.shape\n",
    "            for wi in range(wh - 1):\n",
    "                for wj in range(ww - 1):\n",
    "                    gx = window[wi+1, wj] - window[wi, wj]\n",
    "                    gy = window[wi, wj+1] - window[wi, wj]\n",
    "                    grad_sum += np.sqrt(gx**2 + gy**2)\n",
    "                    count += 1\n",
    "            \n",
    "            if count > 0:\n",
    "                gradient_map[i, j] = grad_sum / count\n",
    "    \n",
    "    return gradient_map\n",
    "\n",
    "print(\"Numba JIT-optimized functions defined:\")\n",
    "print(\"  - compute_local_entropy_numba(image, window_size)\")\n",
    "print(\"  - compute_local_gradient_numba(image, window_size)\")\n"
   ]
