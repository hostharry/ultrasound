    "\n",
    "# Step 3: Create compressed sensing measurement vectors\n",
    "# Generate random Gaussian measurement matrix with 15% sampling rate\n",
    "sampling_rate = 0.15\n",
    "image_size = 256 * 256  # 65536 pixels\n",
    "n_measurements = int(sampling_rate * image_size)  # 9830 measurements\n",
    "\n",
    "print(f\"Compressed sensing parameters:\")\n",
    "print(f\"  Sampling rate: {sampling_rate * 100}%\")\n",
    "print(f\"  Image size: {image_size} pixels\")\n",
    "print(f\"  Number of measurements: {n_measurements}\")\n",
    "\n",
    "# Generate measurement matrix with fixed seed for reproducibility\n",
    "np.random.seed(42)\n",
    "A = np.random.randn(n_measurements, image_size) / np.sqrt(n_measurements)\n",
    "print(f\"  Measurement matrix shape: {A.shape}\")\n",
    "\n",
    "# Generate measurement vectors for all images\n",
    "# Add Gaussian noise to achieve 25 dB SNR\n",
    "target_snr_db = 25\n",
    "all_measurements = []\n",
    "\n",
    "np.random.seed(43)  # Separate seed for noise\n",
    "for i, img in enumerate(all_images):\n",
    "    # Flatten image\n",
    "    x = img.flatten()\n",
    "    \n",
    "    # Generate clean measurements\n",
    "    y_clean = A @ x\n",
    "    \n",
    "    # Add noise to achieve target SNR\n",
    "    signal_power = np.mean(y_clean ** 2)\n",
    "    noise_power = signal_power / (10 ** (target_snr_db / 10))\n",
    "    noise = np.sqrt(noise_power) * np.random.randn(n_measurements)\n",
    "    y = y_clean + noise\n",
    "    \n",
    "    all_measurements.append(y)\n",
    "\n",
    "print(f\"Generated measurement vectors for {len(all_measurements)} images\")\n",
    "print(f\"  Measurement vector shape: {all_measurements[0].shape}\")\n"
