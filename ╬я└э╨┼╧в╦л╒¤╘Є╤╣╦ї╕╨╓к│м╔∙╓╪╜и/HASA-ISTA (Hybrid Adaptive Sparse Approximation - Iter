    "\n",
    "# Step 3: Implement helper functions for the HASA-ISTA algorithm\n",
    "\n",
    "def compute_local_entropy(image, window_size=7):\n",
    "    \"\"\"\n",
    "    Compute local entropy map for an image.\n",
    "    Higher entropy indicates more complex/textured regions.\n",
    "    \"\"\"\n",
    "    from scipy.stats import entropy\n",
    "    \n",
    "    def local_entropy_func(values):\n",
    "        # Create histogram and compute entropy\n",
    "        hist, _ = np.histogram(values, bins=10, range=(0, 1))\n",
    "        hist = hist + 1e-10  # Avoid log(0)\n",
    "        return entropy(hist)\n",
    "    \n",
    "    entropy_map = generic_filter(image, local_entropy_func, size=window_size, mode='reflect')\n",
    "    return entropy_map\n",
    "\n",
    "def compute_gradient_magnitude(image):\n",
    "    \"\"\"\n",
    "    Compute gradient magnitude map using Sobel operators.\n",
    "    Higher gradients indicate edges/boundaries.\n",
    "    \"\"\"\n",
    "    grad_x = sobel(image, axis=1)\n",
    "    grad_y = sobel(image, axis=0)\n",
    "    grad_magnitude = np.sqrt(grad_x**2 + grad_y**2)\n",
    "    return grad_magnitude\n",
    "\n",
    "def normalize_map(map_array, min_val=0.1, max_val=1.0):\n",
    "    \"\"\"\n",
    "    Normalize a map to range [min_val, max_val].\n",
    "    This prevents weights from becoming too small or too large.\n",
    "    \"\"\"\n",
    "    map_min = map_array.min()\n",
    "    map_max = map_array.max()\n",
    "    if map_max - map_min < 1e-10:\n",
    "        return np.ones_like(map_array) * min_val\n",
    "    normalized = (map_array - map_min) / (map_max - map_min)\n",
    "    return normalized * (max_val - min_val) + min_val\n",
    "\n",
    "print(\"Helper functions defined successfully\")\n"
   ]
