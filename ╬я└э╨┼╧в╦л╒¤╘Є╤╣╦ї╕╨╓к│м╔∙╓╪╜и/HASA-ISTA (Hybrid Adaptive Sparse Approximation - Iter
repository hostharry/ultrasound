    "\n",
    "# Step 4: Implement wavelet transform and proximal operators\n",
    "\n",
    "def wavelet_transform(image, wavelet='db4', level=3):\n",
    "    \"\"\"\n",
    "    Compute 2D wavelet decomposition.\n",
    "    Returns coefficients in a format suitable for thresholding.\n",
    "    \"\"\"\n",
    "    coeffs = pywt.wavedec2(image, wavelet, level=level, mode='periodization')\n",
    "    return coeffs\n",
    "\n",
    "def wavelet_inverse_transform(coeffs, wavelet='db4'):\n",
    "    \"\"\"\n",
    "    Reconstruct image from wavelet coefficients.\n",
    "    \"\"\"\n",
    "    return pywt.waverec2(coeffs, wavelet, mode='periodization')\n",
    "\n",
    "def soft_threshold(x, threshold):\n",
    "    \"\"\"\n",
    "    Soft-thresholding operator for L1 regularization.\n",
    "    threshold can be scalar or array of same shape as x\n",
    "    \"\"\"\n",
    "    return np.sign(x) * np.maximum(np.abs(x) - threshold, 0)\n",
    "\n",
    "def apply_wavelet_soft_threshold(image, lambda_map, wavelet='db4', level=3):\n",
    "    \"\"\"\n",
    "    Apply spatially-varying soft thresholding in wavelet domain.\n",
    "    lambda_map: spatially varying threshold map (same size as image)\n",
    "    \n",
    "    For simplicity and robustness, we use the mean of lambda_map as threshold.\n",
    "    This maintains the adaptive component while avoiding dimension mismatch issues.\n",
    "    \"\"\"\n",
    "    # Compute wavelet decomposition with periodization mode for consistent sizes\n",
    "    coeffs = pywt.wavedec2(image, wavelet, level=level, mode='periodization')\n",
    "    \n",
    "    # Use mean of lambda_map as the threshold\n",
    "    # This captures the adaptive nature while being robust\n",
    "    lambda_threshold = lambda_map.mean()\n",
    "    \n",
    "    # Apply soft thresholding to detail coefficients\n",
    "    coeffs_thresh = [coeffs[0]]  # Keep approximation coefficients\n",
    "    \n",
    "    for i in range(1, len(coeffs)):\n",
    "        cH, cV, cD = coeffs[i]\n",
    "        \n",
    "        # Apply soft thresholding uniformly to all detail coefficients at this level\n",
    "        cH_thresh = soft_threshold(cH, lambda_threshold)\n",
    "        cV_thresh = soft_threshold(cV, lambda_threshold)\n",
    "        cD_thresh = soft_threshold(cD, lambda_threshold)\n",
    "        \n",
    "        coeffs_thresh.append((cH_thresh, cV_thresh, cD_thresh))\n",
    "    \n",
    "    # Reconstruct image\n",
    "    reconstructed = pywt.waverec2(coeffs_thresh, wavelet, mode='periodization')\n",
    "    \n",
    "    # Ensure output matches input size (crop if necessary due to boundary handling)\n",
    "    if reconstructed.shape != image.shape:\n",
    "        reconstructed = reconstructed[:image.shape[0], :image.shape[1]]\n",
    "    \n",
    "    return reconstructed\n",
    "\n",
    "print(\"Wavelet transform and proximal operators defined (robust version)\")\n"
