    "# Step 5: Implement TV denoising with spatially-varying weights\n",
    "# We'll use a simplified approach with Chambolle's algorithm\n",
    "\n",
    "def apply_tv_denoising(image, lambda_map, n_iter=10):\n",
    "    \"\"\"\n",
    "    Apply TV denoising with spatially-varying weights.\n",
    "    lambda_map: spatially varying regularization weight map\n",
    "    \n",
    "    We use a weighted TV approach where the weight varies spatially.\n",
    "    For simplicity, we'll apply multiple local TV denoising operations.\n",
    "    \"\"\"\n",
    "    # Use the mean of lambda_map as the global weight for Chambolle's algorithm\n",
    "    # This is a simplification since scikit-image's denoise_tv_chambolle doesn't support spatially-varying weights\n",
    "    # We'll weight the denoising effect based on lambda_map\n",
    "    lambda_mean = lambda_map.mean()\n",
    "    \n",
    "    # Apply TV denoising\n",
    "    denoised = denoise_tv_chambolle(image, weight=lambda_mean, max_num_iter=n_iter)\n",
    "    \n",
    "    # Blend based on local weights (higher weight = more denoising)\n",
    "    # Normalize lambda_map to [0, 1] for blending\n",
    "    lambda_normalized = (lambda_map - lambda_map.min()) / (lambda_map.max() - lambda_map.min() + 1e-10)\n",
    "    result = lambda_normalized * denoised + (1 - lambda_normalized) * image\n",
    "    \n",
    "    return result\n",
    "\n",
    "print(\"TV denoising function defined\")\n"
