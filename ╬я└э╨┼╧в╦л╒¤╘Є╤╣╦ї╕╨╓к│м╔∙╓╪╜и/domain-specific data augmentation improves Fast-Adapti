    "# Optimized local variance computation using variance as proxy\n",
    "def compute_local_variance(img, window_size=9):\n",
    "    \"\"\"Fast approximation of local entropy using local variance\"\"\"\n",
    "    from scipy.ndimage import uniform_filter\n",
    "    \n",
    "    # Local mean\n",
    "    local_mean = uniform_filter(img, size=window_size, mode='nearest')\n",
    "    # Local mean of squares\n",
    "    local_mean_sq = uniform_filter(img**2, size=window_size, mode='nearest')\n",
    "    # Local variance\n",
    "    local_var = local_mean_sq - local_mean**2\n",
    "    return local_var\n",
