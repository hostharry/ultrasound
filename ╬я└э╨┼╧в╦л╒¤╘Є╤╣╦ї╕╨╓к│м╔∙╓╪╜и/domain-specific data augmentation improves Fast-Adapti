    "\n",
    "# Define lightweight U-Net architecture for weight prediction\n",
    "# This CNN takes the initial backprojection and predicts adaptive weight maps\n",
    "\n",
    "class UNet(nn.Module):\n",
    "    \"\"\"Lightweight U-Net for predicting adaptive weights\"\"\"\n",
    "    \n",
    "    def __init__(self, in_channels=1, out_channels=2):\n",
    "        super(UNet, self).__init__()\n",
    "        \n",
    "        # Encoder\n",
    "        self.enc1 = self.conv_block(in_channels, 16)\n",
    "        self.pool1 = nn.MaxPool2d(2)\n",
    "        \n",
    "        self.enc2 = self.conv_block(16, 32)\n",
    "        self.pool2 = nn.MaxPool2d(2)\n",
    "        \n",
    "        self.enc3 = self.conv_block(32, 64)\n",
    "        self.pool3 = nn.MaxPool2d(2)\n",
    "        \n",
    "        # Bottleneck\n",
    "        self.bottleneck = self.conv_block(64, 128)\n",
    "        \n",
    "        # Decoder\n",
    "        self.upconv3 = nn.ConvTranspose2d(128, 64, 2, stride=2)\n",
    "        self.dec3 = self.conv_block(128, 64)\n",
    "        \n",
    "        self.upconv2 = nn.ConvTranspose2d(64, 32, 2, stride=2)\n",
    "        self.dec2 = self.conv_block(64, 32)\n",
    "        \n",
    "        self.upconv1 = nn.ConvTranspose2d(32, 16, 2, stride=2)\n",
    "        self.dec1 = self.conv_block(32, 16)\n",
    "        \n",
    "        # Output layer: 2 channels (TV weight map, wavelet threshold map)\n",
    "        self.out = nn.Conv2d(16, out_channels, 1)\n",
    "        \n",
