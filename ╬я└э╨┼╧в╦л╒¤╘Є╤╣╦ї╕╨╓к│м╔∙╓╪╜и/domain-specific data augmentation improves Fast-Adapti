    "\n",
    "# Implement Slow Adaptive-HASA algorithm\n",
    "# Sequential TV denoising followed by wavelet thresholding with adaptive weights\n",
    "\n",
    "def adaptive_hasa_slow(A, y, img_shape, n_iterations=50, step_size=0.001,\n",
    "                       tv_weight_base=0.1, wavelet_threshold_base=0.05,\n",
    "                       window_size=9, update_weights_every=5):\n",
    "    \"\"\"\n",
    "    Slow Adaptive-HASA with periodic weight updates\n",
    "    \n",
    "    Parameters:\n",
    "    - A: measurement matrix\n",
    "    - y: noisy measurements\n",
    "    - img_shape: target image shape\n",
    "    - n_iterations: number of iterations\n",
    "    - step_size: gradient descent step size\n",
    "    - tv_weight_base: base TV denoising weight\n",
    "    - wavelet_threshold_base: base wavelet threshold\n",
    "    - window_size: window size for local statistics\n",
    "    - update_weights_every: update adaptive weights every N iterations\n",
    "    \"\"\"\n",
    "    # Initial backprojection\n",
    "    x = initial_backprojection(A, y, img_shape)\n",
    "    \n",
    "    for it in range(n_iterations):\n",
    "        # Update adaptive weights periodically (not every iteration for efficiency)\n",
    "        if it % update_weights_every == 0:\n",
    "            # Compute local statistics\n",
    "            local_grad = compute_local_gradient(x, window_size=window_size)\n",
    "            local_entropy = compute_local_entropy(x, window_size=window_size)\n",
    "            \n",
    "            # Normalize to [0, 1] range\n",
    "            grad_norm = (local_grad - local_grad.min()) / (local_grad.max() - local_grad.min() + 1e-10)\n",
    "            entropy_norm = (local_entropy - local_entropy.min()) / (local_entropy.max() - local_entropy.min() + 1e-10)\n",
    "            \n",
    "            # Adaptive weights: higher weights for regions with more structure\n",
    "            tv_weight_map = tv_weight_base * (1 + grad_norm)\n",
    "            wavelet_threshold_map = wavelet_threshold_base * (1 + entropy_norm)\n",
    "            \n",
    "            # Use mean values for TV (spatially-invariant TV in scikit-image)\n",
    "            tv_weight = tv_weight_map.mean()\n",
    "        \n",
    "        # Data fidelity gradient: A^T(Ax - y)\n",
    "        residual = A @ x.flatten() - y\n",
    "        gradient = A.T @ residual\n",
    "        gradient = gradient.reshape(img_shape)\n",
    "        \n",
    "        # Gradient descent step\n",
    "        x = x - step_size * gradient\n",
    "        \n",
    "        # Sequential TV denoising then wavelet thresholding (order matters!)\n",
    "        x = denoise_tv_chambolle(x, weight=tv_weight)\n",
    "        x = wavelet_soft_threshold(x, threshold=wavelet_threshold_map.mean(), \n",
    "                                   wavelet='db4', level=3)\n",
    "        \n",
    "        # Clip to valid range\n",
    "        x = np.clip(x, 0, 1)\n",
    "    \n",
    "    return x\n",
    "\n",
    "print(\"Slow Adaptive-HASA algorithm implemented\")\n"
   ]
