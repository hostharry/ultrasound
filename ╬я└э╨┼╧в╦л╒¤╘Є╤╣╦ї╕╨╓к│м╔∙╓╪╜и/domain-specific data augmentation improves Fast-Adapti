    "\n",
    "# Step 2: Implement compressed sensing simulation\n",
    "# Resize to 256x256, convert to grayscale, normalize to [0,1]\n",
    "# Create Gaussian measurement matrix with 15% sampling rate\n",
    "# Add Gaussian noise for 25dB SNR\n",
    "\n",
    "def preprocess_image(img, target_size=(256, 256)):\n",
    "    \"\"\"Resize and normalize image to [0, 1]\"\"\"\n",
    "    img_pil = Image.fromarray(img)\n",
    "    img_resized = img_pil.resize(target_size, Image.BILINEAR)\n",
    "    img_normalized = np.array(img_resized, dtype=np.float64) / 255.0\n",
    "    return img_normalized\n",
    "\n",
    "def create_measurement_matrix(n_measurements, n_pixels, seed=42):\n",
    "    \"\"\"Create Gaussian random measurement matrix\"\"\"\n",
    "    np.random.seed(seed)\n",
    "    A = np.random.randn(n_measurements, n_pixels) / np.sqrt(n_measurements)\n",
    "    return A\n",
    "\n",
    "def add_gaussian_noise(y, target_snr_db=25, seed=43):\n",
    "    \"\"\"Add Gaussian noise to achieve target SNR\"\"\"\n",
    "    np.random.seed(seed)\n",
    "    signal_power = np.mean(y ** 2)\n",
    "    snr_linear = 10 ** (target_snr_db / 10)\n",
    "    noise_power = signal_power / snr_linear\n",
    "    noise = np.random.randn(len(y)) * np.sqrt(noise_power)\n",
    "    return y + noise\n",
    "\n",
    "def simulate_cs_acquisition(img, sampling_rate=0.15, target_snr_db=25, \n",
    "                            measurement_seed=42, noise_seed=43):\n",
    "    \"\"\"Complete CS simulation pipeline\"\"\"\n",
    "    # Flatten image\n",
    "    img_flat = img.flatten()\n",
    "    n_pixels = len(img_flat)\n",
    "    n_measurements = int(sampling_rate * n_pixels)\n",
    "    \n",
    "    # Create measurement matrix\n",
    "    A = create_measurement_matrix(n_measurements, n_pixels, seed=measurement_seed)\n",
    "    \n",
    "    # Take measurements\n",
    "    y = A @ img_flat\n",
    "    \n",
    "    # Add noise\n",
    "    y_noisy = add_gaussian_noise(y, target_snr_db, seed=noise_seed)\n",
    "    \n",
    "    return A, y_noisy\n",
    "\n",
    "# Test the CS simulation on first training image\n",
    "test_img = preprocess_image(train_images[0][0])\n",
    "print(f\"Preprocessed image shape: {test_img.shape}\")\n",
    "print(f\"Image value range: [{test_img.min():.3f}, {test_img.max():.3f}]\")\n",
