    "\n",
    "# Implement reconstruction algorithms\n",
    "# 1. Slow Adaptive-HASA (baseline)\n",
    "# 2. Fast-Adaptive-HASA (CNN-based weight prediction)\n",
    "\n",
    "def initial_backprojection(A, y, img_shape):\n",
    "    \"\"\"Initial reconstruction using backprojection (A^T @ y)\"\"\"\n",
    "    x_init = A.T @ y\n",
    "    return x_init.reshape(img_shape)\n",
    "\n",
    "def wavelet_soft_threshold(img, threshold, wavelet='db4', level=3):\n",
    "    \"\"\"Apply wavelet soft thresholding\"\"\"\n",
    "    coeffs = pywt.wavedec2(img, wavelet=wavelet, level=level)\n",
    "    \n",
    "    # Threshold detail coefficients\n",
    "    coeffs_thresh = [coeffs[0]]  # Keep approximation coefficients\n",
    "    for detail_level in coeffs[1:]:\n",
    "        coeffs_thresh.append(tuple([\n",
    "            pywt.threshold(c, threshold, mode='soft') for c in detail_level\n",
    "        ]))\n",
    "    \n",
    "    return pywt.waverec2(coeffs_thresh, wavelet=wavelet)\n",
    "\n",
    "def compute_local_entropy(img, window_size=9):\n",
    "    \"\"\"Compute local entropy for adaptive weighting\"\"\"\n",
    "    from scipy.stats import entropy\n",
    "    \n",
    "    def local_entropy_func(values):\n",
    "        # Compute histogram-based entropy\n",
    "        hist, _ = np.histogram(values, bins=10, range=(0, 1))\n",
    "        hist = hist + 1e-10  # Avoid log(0)\n",
    "        return entropy(hist)\n",
    "    \n",
    "    entropy_map = generic_filter(img, local_entropy_func, size=window_size, mode='nearest')\n",
    "    return entropy_map\n",
    "\n",
    "def compute_local_gradient(img, window_size=9):\n",
    "    \"\"\"Compute local gradient magnitude for adaptive weighting\"\"\"\n",
    "    # Compute gradient using Sobel-like operators\n",
    "    from scipy.ndimage import sobel\n",
    "    \n",
    "    grad_x = sobel(img, axis=1)\n",
    "    grad_y = sobel(img, axis=0)\n",
    "    grad_mag = np.sqrt(grad_x**2 + grad_y**2)\n",
    "    \n",
    "    # Compute local average gradient\n",
    "    from scipy.ndimage import uniform_filter\n",
    "    local_grad = uniform_filter(grad_mag, size=window_size, mode='nearest')\n",
    "    \n",
    "    return local_grad\n",
    "\n",
    "print(\"Reconstruction functions defined\")\n"
