    "\n",
    "# Define TV and Wavelet proximal operators for ADMM\n",
    "def tv_prox_operator(v, lambda_tv, max_iter=100):\n",
    "    \"\"\"\n",
    "    TV proximal operator using Chambolle's algorithm.\n",
    "    For scalar lambda_tv, uses skimage implementation.\n",
    "    \"\"\"\n",
    "    from skimage.restoration import denoise_tv_chambolle\n",
    "    # Weight parameter in skimage is the inverse of our lambda\n",
    "    weight = 1.0 / lambda_tv if lambda_tv > 0 else 1e10\n",
    "    return denoise_tv_chambolle(v, weight=weight, max_num_iter=max_iter)\n",
    "\n",
    "def wavelet_soft_threshold(coeffs, threshold):\n",
    "    \"\"\"Apply soft thresholding to wavelet coefficients\"\"\"\n",
    "    return pywt.threshold(coeffs, threshold, mode='soft')\n",
    "\n",
    "def wavelet_prox_operator(v, lambda_wav, wavelet='db4', level=3):\n",
    "    \"\"\"\n",
    "    Wavelet proximal operator using soft thresholding.\n",
    "    Handles PyWavelets coefficient structure properly.\n",
    "    \"\"\"\n",
    "    # Reshape v to 2D if needed\n",
    "    shape = v.shape\n",
    "    if len(shape) == 1:\n",
    "        # Assume square image\n",
    "        n = int(np.sqrt(len(v)))\n",
    "        v_2d = v.reshape(n, n)\n",
    "    else:\n",
    "        v_2d = v\n",
    "    \n",
    "    # Wavelet decomposition\n",
    "    coeffs = pywt.wavedec2(v_2d, wavelet=wavelet, level=level, mode='periodization')\n",
    "    \n",
    "    # Apply soft thresholding to detail coefficients (not approximation)\n",
    "    coeffs_thresh = [coeffs[0]]  # Keep approximation unchanged\n",
    "    for detail_level in coeffs[1:]:\n",
    "        coeffs_thresh.append(tuple(wavelet_soft_threshold(c, lambda_wav) for c in detail_level))\n",
    "    \n",
    "    # Reconstruct\n",
    "    v_denoised = pywt.waverec2(coeffs_thresh, wavelet=wavelet, mode='periodization')\n",
    "    \n",
    "    # Handle size mismatch due to pywavelets\n",
    "    if v_denoised.shape != v_2d.shape:\n",
    "        v_denoised = v_denoised[:v_2d.shape[0], :v_2d.shape[1]]\n",
    "    \n",
    "    # Return in original shape\n",
    "    if len(shape) == 1:\n",
    "        return v_denoised.flatten()\n",
    "    else:\n",
    "        return v_denoised\n",
    "\n",
    "print(\"Proximal operators defined\")\n"
   ]
