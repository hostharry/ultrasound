    "\n",
    "# Define core simulation functions for compressed sensing\n",
    "def load_and_preprocess_image(img_path, target_size=(128, 128)):\n",
    "    \"\"\"Load image, resize, convert to grayscale, normalize to [0,1]\"\"\"\n",
    "    img = Image.open(img_path).convert('L')\n",
    "    img = img.resize(target_size, Image.BILINEAR)\n",
    "    img_array = np.array(img, dtype=np.float64) / 255.0\n",
    "    return img_array\n",
    "\n",
    "def load_mask(mask_path, target_size=(128, 128)):\n",
    "    \"\"\"Load and preprocess mask\"\"\"\n",
    "    mask = Image.open(mask_path).convert('L')\n",
    "    mask = mask.resize(target_size, Image.NEAREST)\n",
    "    mask_array = np.array(mask, dtype=np.float64) / 255.0\n",
    "    mask_array = (mask_array > 0.5).astype(np.float64)\n",
    "    return mask_array\n",
    "\n",
    "def create_measurement_matrix(n, m, seed=42):\n",
    "    \"\"\"Create random Gaussian measurement matrix\"\"\"\n",
    "    rng = np.random.RandomState(seed)\n",
    "    A = rng.randn(m, n) / np.sqrt(m)\n",
    "    return A\n",
    "\n",
    "def add_noise_to_measurements(y, target_snr_db=25, seed=43):\n",
    "    \"\"\"Add Gaussian noise to measurements to achieve target SNR\"\"\"\n",
    "    rng = np.random.RandomState(seed)\n",
    "    signal_power = np.mean(y ** 2)\n",
    "    snr_linear = 10 ** (target_snr_db / 10)\n",
    "    noise_power = signal_power / snr_linear\n",
    "    noise = rng.randn(len(y)) * np.sqrt(noise_power)\n",
    "    return y + noise\n",
    "\n",
    "def compute_lipschitz_constant(A, max_iter=100):\n",
    "    \"\"\"Estimate Lipschitz constant as largest eigenvalue of A^T A using power iteration\"\"\"\n",
    "    n = A.shape[1]\n",
    "    x = np.random.randn(n)\n",
    "    x = x / np.linalg.norm(x)\n",
    "    \n",
    "    for _ in range(max_iter):\n",
    "        x = A.T @ (A @ x)\n",
    "        x = x / np.linalg.norm(x)\n",
    "    \n",
    "    L = np.linalg.norm(A @ x) ** 2\n",
    "    return L\n",
    "\n",
    "print(\"Core simulation functions defined\")\n"
