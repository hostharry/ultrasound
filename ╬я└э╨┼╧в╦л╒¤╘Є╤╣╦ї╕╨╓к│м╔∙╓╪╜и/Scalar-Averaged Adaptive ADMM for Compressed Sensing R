    "\n",
    "# Define the Scalar-Averaged Adaptive ADMM solver\n",
    "def admm_scalar_averaged_adaptive(A, y, img_shape, rho=1.0, max_iter=100, \n",
    "                                   base_lambda_tv=0.01, base_lambda_wav=0.01,\n",
    "                                   tol=1e-4, cg_maxiter=100):\n",
    "    \"\"\"\n",
    "    ADMM solver with scalar-averaged adaptive weights.\n",
    "    \n",
    "    Key modification: At each iteration, compute spatial weight maps from current estimate,\n",
    "    then AVERAGE them to scalar values before using in proximal operators.\n",
    "    \n",
    "    Args:\n",
    "        A: Measurement matrix (m x n)\n",
    "        y: Noisy measurements (m,)\n",
    "        img_shape: Tuple (height, width) for reshaping\n",
    "        rho: ADMM penalty parameter\n",
    "        max_iter: Number of ADMM iterations\n",
    "        base_lambda_tv: Base TV regularization parameter\n",
    "        base_lambda_wav: Base wavelet regularization parameter\n",
    "        tol: Convergence tolerance\n",
    "        cg_maxiter: Max iterations for CG solver\n",
    "        \n",
    "    Returns:\n",
    "        x: Reconstructed image (flattened)\n",
    "        convergence_info: Dictionary with convergence metrics\n",
    "    \"\"\"\n",
    "    m, n = A.shape\n",
    "    \n",
    "    # Initialize variables\n",
    "    x = A.T @ y  # Initial backprojection\n",
    "    z1 = x.copy()  # TV auxiliary variable\n",
    "    z2 = x.copy()  # Wavelet auxiliary variable\n",
    "    u1 = np.zeros(n)  # TV scaled dual variable\n",
    "    u2 = np.zeros(n)  # Wavelet scaled dual variable\n",
    "    \n",
    "    # Track convergence\n",
    "    convergence_info = {\n",
    "        'iterations': 0,\n",
    "        'cg_failures': 0,\n",
    "        'residuals': [],\n",
    "        'lambda_tv_history': [],\n",
    "        'lambda_wav_history': []\n",
    "    }\n",
    "    \n",
    "    # Precompute A^T A as LinearOperator for CG solver\n",
    "    def AtA_plus_2rho(v):\n",
    "        return A.T @ (A @ v) + 2 * rho * v\n",
    "    \n",
    "    AtA_op = LinearOperator((n, n), matvec=AtA_plus_2rho)\n",
    "    \n",
    "    # ADMM iterations\n",
    "    for k in range(max_iter):\n",
    "        x_old = x.copy()\n",
    "        \n",
    "        # Step 1: x-update using Conjugate Gradient\n",
    "        # Solve: (A^T A + 2*rho*I) x = A^T y + rho(z1 + z2 - u1 - u2)\n",
    "        b = A.T @ y + rho * (z1 + z2 - u1 - u2)\n",
    "        # Note: scipy.sparse.linalg.cg uses 'atol' not 'tol'\n",
    "        x, cg_info = cg(AtA_op, b, x0=x, maxiter=cg_maxiter, atol=1e-6)\n",
    "        \n",
    "        # Check for CG convergence failure\n",
    "        if cg_info > 0:\n",
    "            convergence_info['cg_failures'] += 1\n",
    "            # Continue with best estimate rather than failing completely\n",
    "        \n",
    "        # Step 2: Compute adaptive weights from current estimate\n",
    "        x_2d = x.reshape(img_shape)\n",
    "        tv_weight_map, wav_weight_map = compute_adaptive_weights(\n",
    "            x_2d, base_lambda_tv=base_lambda_tv, base_lambda_wav=base_lambda_wav\n",
    "        )\n",
    "        \n",
    "        # **CRITICAL AVERAGING STEP**: Average spatial maps to scalars\n",
    "        lambda_tv_scalar = np.mean(tv_weight_map)\n",
    "        lambda_wav_scalar = np.mean(wav_weight_map)\n",
    "        \n",
    "        # Track weight evolution\n",
    "        convergence_info['lambda_tv_history'].append(lambda_tv_scalar)\n",
    "        convergence_info['lambda_wav_history'].append(lambda_wav_scalar)\n",
    "        \n",
    "        # Step 3: z1-update (TV proximal with scalar weight)\n",
    "        v1 = x + u1\n",
    "        v1_2d = v1.reshape(img_shape)\n",
    "        z1_2d = tv_prox_operator(v1_2d, rho * lambda_tv_scalar)\n",
