    "        z2 = z2_2d.flatten()\n",
    "        \n",
    "        # Step 5: Dual variable updates\n",
    "        u1 = u1 + (x - z1)\n",
    "        u2 = u2 + (x - z2)\n",
    "        \n",
    "        # Check convergence\n",
