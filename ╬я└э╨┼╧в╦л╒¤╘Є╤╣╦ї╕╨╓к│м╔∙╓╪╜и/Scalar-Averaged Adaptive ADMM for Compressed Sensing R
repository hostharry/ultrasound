    "\n",
    "# Define adaptive weight computation functions\n",
    "def compute_local_gradient_strength(img, window_size=3):\n",
    "    \"\"\"Compute local gradient magnitude for adaptive TV weighting\"\"\"\n",
    "    grad_y, grad_x = np.gradient(img)\n",
    "    grad_mag = np.sqrt(grad_x**2 + grad_y**2)\n",
    "    \n",
    "    # Apply local averaging to smooth the gradient map\n",
    "    from scipy.ndimage import uniform_filter\n",
    "    local_grad = uniform_filter(grad_mag, size=window_size)\n",
    "    \n",
    "    return local_grad\n",
    "\n",
    "def compute_local_entropy(img, window_size=3):\n",
    "    \"\"\"Compute local entropy for adaptive wavelet weighting\"\"\"\n",
    "    from scipy.stats import entropy as scipy_entropy\n",
    "    from skimage.util import view_as_windows\n",
    "    \n",
    "    # Quantize image to compute entropy\n",
    "    img_quantized = (img * 255).astype(np.uint8)\n",
    "    \n",
    "    # Pad image to handle boundaries\n",
    "    pad_size = window_size // 2\n",
    "    img_padded = np.pad(img_quantized, pad_size, mode='reflect')\n",
    "    \n",
    "    # Create sliding windows\n",
    "    windows = view_as_windows(img_padded, (window_size, window_size))\n",
    "    \n",
    "    # Compute entropy for each window\n",
    "    entropy_map = np.zeros(img.shape)\n",
    "    for i in range(windows.shape[0]):\n",
    "        for j in range(windows.shape[1]):\n",
    "            window = windows[i, j].flatten()\n",
    "            hist, _ = np.histogram(window, bins=16, range=(0, 255))\n",
    "            hist = hist / hist.sum()\n",
    "            entropy_map[i, j] = scipy_entropy(hist + 1e-10)\n",
    "    \n",
    "    return entropy_map\n",
    "\n",
    "def compute_adaptive_weights(img, base_lambda_tv=0.01, base_lambda_wav=0.01):\n",
    "    \"\"\"\n",
    "    Compute spatially-varying weight maps for TV and wavelet regularization.\n",
    "    Returns normalized spatial maps.\n",
    "    \"\"\"\n",
    "    # Compute local features\n",
    "    grad_strength = compute_local_gradient_strength(img)\n",
    "    local_ent = compute_local_entropy(img)\n",
    "    \n",
    "    # Normalize features to [0, 1]\n",
    "    grad_norm = (grad_strength - grad_strength.min()) / (grad_strength.max() - grad_strength.min() + 1e-10)\n",
    "    ent_norm = (local_ent - local_ent.min()) / (local_ent.max() - local_ent.min() + 1e-10)\n",
    "    \n",
    "    # Create weight maps: increase regularization at edges (high gradient)\n",
    "    # and at high entropy regions\n",
    "    tv_weight_map = base_lambda_tv * (1.0 + grad_norm)\n",
    "    wav_weight_map = base_lambda_wav * (1.0 + ent_norm)\n",
    "    \n",
    "    return tv_weight_map, wav_weight_map\n",
    "\n",
    "print(\"Adaptive weight computation functions defined\")\n"
   ]
