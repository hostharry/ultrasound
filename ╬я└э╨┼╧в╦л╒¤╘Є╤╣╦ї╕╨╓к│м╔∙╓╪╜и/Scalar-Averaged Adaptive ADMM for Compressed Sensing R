    "\n",
    "# The ADMM is running but very slow (6+ minutes per image)\n",
    "# The entropy computation is the bottleneck (nested loops over all pixels)\n",
    "# Let's optimize the entropy calculation and reduce ADMM iterations\n",
    "\n",
    "def compute_local_entropy_fast(img, window_size=3):\n",
    "    \"\"\"Fast local entropy computation using vectorized operations\"\"\"\n",
    "    from skimage.filters.rank import entropy as rank_entropy\n",
    "    from skimage.morphology import disk\n",
    "    \n",
    "    # Convert to uint8 for rank filter\n",
    "    img_uint8 = (img * 255).astype(np.uint8)\n",
    "    \n",
    "    # Use scikit-image's optimized rank entropy\n",
    "    entropy_map = rank_entropy(img_uint8, disk(window_size//2))\n",
    "    \n",
    "    # Normalize to [0, 1]\n",
    "    entropy_map = entropy_map.astype(np.float64) / 255.0\n",
    "    \n",
    "    return entropy_map\n",
    "\n",
    "def compute_adaptive_weights_fast(img, base_lambda_tv=0.01, base_lambda_wav=0.01):\n",
    "    \"\"\"\n",
    "    Fast version of adaptive weight computation using optimized entropy.\n",
    "    \"\"\"\n",
    "    # Compute local features\n",
    "    grad_strength = compute_local_gradient_strength(img)\n",
    "    local_ent = compute_local_entropy_fast(img)\n",
    "    \n",
    "    # Normalize features to [0, 1]\n",
    "    grad_norm = (grad_strength - grad_strength.min()) / (grad_strength.max() - grad_strength.min() + 1e-10)\n",
    "    ent_norm = (local_ent - local_ent.min()) / (local_ent.max() - local_ent.min() + 1e-10)\n",
    "    \n",
    "    # Create weight maps\n",
    "    tv_weight_map = base_lambda_tv * (1.0 + grad_norm)\n",
    "    wav_weight_map = base_lambda_wav * (1.0 + ent_norm)\n",
    "    \n",
    "    return tv_weight_map, wav_weight_map\n",
    "\n",
    "print(\"Fast adaptive weight functions defined\")\n"
