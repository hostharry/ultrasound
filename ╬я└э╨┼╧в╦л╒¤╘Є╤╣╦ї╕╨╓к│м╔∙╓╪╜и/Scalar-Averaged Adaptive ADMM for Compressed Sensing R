    "# Define evaluation functions\n",
    "def compute_tumor_roi_metrics(recon_img, ground_truth, mask):\n",
    "    \"\"\"\n",
    "    Compute PSNR and SSIM for tumor ROI using bounding box approach.\n",
    "    Returns metrics only for images with valid tumor regions.\n",
