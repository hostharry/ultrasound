   "source": [
    "\n",
    "# Step 2: Isolate the Tumor ROI SSIM data for TV-only and Adaptive-HASA methods\n",
    "# We have 30 images total (15 benign, 15 malignant), each with 4 methods = 120 rows\n",
    "\n",
    "# Extract TV-only SSIM_Tumor values\n",
    "tv_only_data = data[data['Method'] == 'TV-only'].copy()\n",
    "tv_only_data = tv_only_data.sort_values('Image').reset_index(drop=True)\n",
    "\n",
    "# Extract Adaptive-HASA SSIM_Tumor values\n",
    "adaptive_hasa_data = data[data['Method'] == 'Adaptive-HASA'].copy()\n",
    "adaptive_hasa_data = adaptive_hasa_data.sort_values('Image').reset_index(drop=True)\n",
    "\n",
    "# Verify we have 30 samples for each method\n",
    "print(f\"TV-only samples: {len(tv_only_data)}\")\n",
    "print(f\"Adaptive-HASA samples: {len(adaptive_hasa_data)}\")\n",
    "\n",
    "# Extract the SSIM_Tumor values\n",
    "ssim_tv = tv_only_data['SSIM_Tumor'].values\n",
    "ssim_adaptive = adaptive_hasa_data['SSIM_Tumor'].values\n",
    "\n",
    "print(\"\\nTV-only SSIM_Tumor values (first 10):\")\n",
    "print(ssim_tv[:10])\n",
    "print(\"\\nAdaptive-HASA SSIM_Tumor values (first 10):\")\n",
    "print(ssim_adaptive[:10])\n",
    "\n",
    "# Verify image alignment (same images for both methods)\n",
    "print(\"\\nVerifying image alignment...\")\n",
    "print(\"Images match:\", np.all(tv_only_data['Image'].values == adaptive_hasa_data['Image'].values))\n",
    "print(\"\\nFirst 5 images from both methods:\")\n",
    "print(\"TV-only:\", tv_only_data['Image'].values[:5])\n",
    "print(\"Adaptive-HASA:\", adaptive_hasa_data['Image'].values[:5])\n"
   ]
