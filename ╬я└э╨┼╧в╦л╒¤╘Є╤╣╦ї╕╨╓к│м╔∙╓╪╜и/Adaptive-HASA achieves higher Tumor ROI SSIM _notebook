    "\n",
    "# Step 1: Load the reconstruction results dataset and examine its structure\n",
    "import pandas as pd\n",
    "import numpy as np\n",
    "\n",
    "# Load the dataset\n",
    "data = pd.read_csv('reconstruction_results_15percent_all_methods.csv')\n",
    "\n",
    "# Display basic information about the dataset\n",
    "print(\"Dataset shape:\", data.shape)\n",
    "print(\"\\nColumn names:\")\n",
    "print(data.columns.tolist())\n",
    "print(\"\\nFirst few rows:\")\n",
    "print(data.head(10))\n",
    "print(\"\\nDataset info:\")\n",
    "print(data.info())\n",
    "print(\"\\nUnique methods:\")\n",
    "print(data['Method'].unique() if 'Method' in data.columns else \"Method column not found\")\n"
   ]
  },
