    "\n",
    "# Step 2: Define helper functions for compressed sensing simulation\n",
    "def preprocess_image(img_path, target_size=(128, 128)):\n",
    "    \"\"\"Load, resize, grayscale, and normalize image to [0, 1]\"\"\"\n",
    "    img = io.imread(img_path)\n",
    "    \n",
    "    # Convert to grayscale if needed\n",
    "    if len(img.shape) == 3:\n",
    "        img = np.mean(img, axis=2)\n",
    "    \n",
    "    # Resize\n",
    "    img_resized = transform.resize(img, target_size, anti_aliasing=True, preserve_range=True)\n",
    "    \n",
    "    # Normalize to [0, 1]\n",
    "    img_normalized = (img_resized - img_resized.min()) / (img_resized.max() - img_resized.min() + 1e-10)\n",
    "    \n",
    "    return img_normalized\n",
    "\n",
    "def preprocess_mask(mask_path, target_size=(128, 128)):\n",
    "    \"\"\"Load and resize mask\"\"\"\n",
    "    mask = io.imread(mask_path)\n",
    "    \n",
    "    # Convert to grayscale if needed\n",
    "    if len(mask.shape) == 3:\n",
    "        mask = np.mean(mask, axis=2)\n",
    "    \n",
    "    # Convert to float first, then resize without anti_aliasing to avoid boolean error\n",
    "    mask = mask.astype(float)\n",
    "    \n",
    "    # Resize without anti-aliasing for binary masks\n",
    "    mask_resized = transform.resize(mask, target_size, order=0, anti_aliasing=False, preserve_range=True)\n",
    "    \n",
    "    # Binarize\n",
    "    mask_binary = (mask_resized > 0.5 * mask_resized.max()).astype(float)\n",
    "    \n",
    "    return mask_binary\n",
    "\n",
    "def create_measurement_matrix(n_measurements, n_pixels, seed=42):\n",
    "    \"\"\"Create random Gaussian measurement matrix\"\"\"\n",
    "    np.random.seed(seed)\n",
    "    A = np.random.randn(n_measurements, n_pixels) / np.sqrt(n_measurements)\n",
    "    return A\n",
    "\n",
    "def add_noise_snr(signal, target_snr_db=25, seed=43):\n",
    "    \"\"\"Add Gaussian noise to achieve target SNR\"\"\"\n",
    "    np.random.seed(seed)\n",
    "    signal_power = np.mean(signal ** 2)\n",
    "    snr_linear = 10 ** (target_snr_db / 10)\n",
    "    noise_power = signal_power / snr_linear\n",
    "    noise = np.random.randn(*signal.shape) * np.sqrt(noise_power)\n",
    "    return signal + noise\n",
    "\n",
    "print(\"Helper functions defined\")\n"
   ]
