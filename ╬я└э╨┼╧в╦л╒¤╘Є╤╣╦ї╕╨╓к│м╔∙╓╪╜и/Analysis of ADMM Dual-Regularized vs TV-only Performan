    "# Step 4: Implement optimized ADMM solver with reduced iterations\n",
    "def admm_cs_reconstruction(y, A, shape, lambda_tv=0.01, lambda_wavelet=0.005, \n",
    "                          rho=0.5, max_iter=20, tol=1e-3):\n",
    "    \"\"\"\n",
    "    ADMM solver for compressed sensing with TV + Wavelet regularization\n",
    "    Optimized for speed with fewer iterations\n",
    "    \"\"\"\n",
    "    n_pixels = shape[0] * shape[1]\n",
    "    \n",
    "    # Initialize variables\n",
    "    x = A.T @ y  # Backprojection initialization\n",
    "    z_tv = np.zeros((shape[0], shape[1], 2))\n",
    "    u_tv = np.zeros((shape[0], shape[1], 2))\n",
    "    z_wavelet = x.copy()\n",
    "    u_wavelet = np.zeros(n_pixels)\n",
    "    \n",
    "    ATy = A.T @ y\n",
    "    ATA = A.T @ A\n",
    "    \n",
    "    for iteration in range(max_iter):\n",
    "        x_old = x.copy()\n",
    "        \n",
    "        # x-update: Solve linear system\n",
    "        div_term = divergence_op(z_tv - u_tv, shape)\n",
    "        b = ATy + rho * (div_term + z_wavelet - u_wavelet)\n",
    "        \n",
    "        def matvec(v):\n",
    "            grad_v = gradient_op(v, shape)\n",
    "            div_grad_v = divergence_op(grad_v, shape)\n",
    "            return ATA @ v + 2 * rho * v - rho * div_grad_v\n",
    "        \n",
    "        linear_op = splinalg.LinearOperator((n_pixels, n_pixels), matvec=matvec)\n",
    "        # Reduced CG iterations for speed\n",
    "        x, info = splinalg.cg(linear_op, b, x0=x, rtol=1e-2, atol=1e-8, maxiter=10)\n",
    "        \n",
    "        # z_tv-update: Anisotropic TV soft thresholding\n",
    "        grad_x = gradient_op(x, shape)\n",
    "        v_tv = grad_x + u_tv\n",
    "        v_tv_norm = np.sqrt(v_tv[:, :, 0]**2 + v_tv[:, :, 1]**2)\n",
    "        shrinkage = np.maximum(1 - lambda_tv / (rho * v_tv_norm + 1e-10), 0)\n",
    "        z_tv = v_tv * shrinkage[:, :, np.newaxis]\n",
    "        \n",
    "        # z_wavelet-update: Only if lambda_wavelet > 0\n",
    "        if lambda_wavelet > 0:\n",
    "            v_wavelet = x + u_wavelet\n",
    "            z_wavelet = wavelet_soft_threshold(v_wavelet, lambda_wavelet / rho, shape)\n",
    "        else:\n",
    "            z_wavelet = x + u_wavelet\n",
    "        \n",
    "        # u-updates\n",
    "        u_tv = u_tv + grad_x - z_tv\n",
    "        u_wavelet = u_wavelet + x - z_wavelet\n",
    "        \n",
    "        # Check convergence\n",
    "        residual = np.linalg.norm(x - x_old) / (np.linalg.norm(x_old) + 1e-10)\n",
    "        if residual < tol:\n",
    "            break\n",
    "    \n",
    "    return x.reshape(shape)\n",
    "\n",
    "print(\"ADMM solver implemented (optimized for speed)\")\n"
