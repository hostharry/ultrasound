    "\n",
    "# Step 3: Implement ADMM solver with dual regularization (TV + Wavelet)\n",
    "def gradient_op(x, shape):\n",
    "    \"\"\"Compute gradient operator (forward differences)\"\"\"\n",
    "    x_2d = x.reshape(shape)\n",
    "    grad_x = np.zeros((shape[0], shape[1], 2))\n",
    "    \n",
    "    # Horizontal gradient\n",
    "    grad_x[:-1, :, 0] = x_2d[1:, :] - x_2d[:-1, :]\n",
    "    # Vertical gradient  \n",
    "    grad_x[:, :-1, 1] = x_2d[:, 1:] - x_2d[:, :-1]\n",
    "    \n",
    "    return grad_x\n",
    "\n",
    "def divergence_op(grad, shape):\n",
    "    \"\"\"Compute divergence operator (negative adjoint of gradient)\"\"\"\n",
    "    div = np.zeros(shape)\n",
    "    \n",
    "    # Horizontal component (negative adjoint)\n",
    "    div[:-1, :] -= grad[:-1, :, 0]\n",
    "    div[1:, :] += grad[:-1, :, 0]\n",
    "    \n",
    "    # Vertical component (negative adjoint)\n",
    "    div[:, :-1] -= grad[:, :-1, 1]\n",
    "    div[:, 1:] += grad[:, :-1, 1]\n",
    "    \n",
    "    return div.flatten()\n",
    "\n",
    "def soft_threshold(x, threshold):\n",
    "    \"\"\"Soft thresholding operator\"\"\"\n",
    "    return np.sign(x) * np.maximum(np.abs(x) - threshold, 0)\n",
    "\n",
    "def wavelet_soft_threshold(x, threshold, shape, wavelet='db4', level=3):\n",
    "    \"\"\"Apply soft thresholding in wavelet domain\"\"\"\n",
    "    x_2d = x.reshape(shape)\n",
    "    coeffs = pywt.wavedec2(x_2d, wavelet, level=level)\n",
    "    \n",
    "    # Threshold all coefficients except approximation\n",
    "    coeffs_thresh = [coeffs[0]]\n",
    "    for detail_level in coeffs[1:]:\n",
    "        coeffs_thresh.append(tuple([soft_threshold(c, threshold) for c in detail_level]))\n",
    "    \n",
    "    x_reconstructed = pywt.waverec2(coeffs_thresh, wavelet)\n",
    "    \n",
    "    # Handle size mismatch due to wavelet decomposition\n",
    "    x_reconstructed = x_reconstructed[:shape[0], :shape[1]]\n",
    "    \n",
    "    return x_reconstructed.flatten()\n",
    "\n",
    "print(\"ADMM operators defined\")\n"
   ]
