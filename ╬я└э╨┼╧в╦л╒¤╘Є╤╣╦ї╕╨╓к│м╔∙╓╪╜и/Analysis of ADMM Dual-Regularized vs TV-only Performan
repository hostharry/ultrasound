    "# Step 5: Calculate tumor ROI SSIM with bounding box approach\n",
    "def calculate_roi_ssim(img_recon, img_true, mask, use_bbox=True):\n",
    "    \"\"\"\n",
    "    Calculate SSIM on tumor ROI using bounding box approach\n",
    "    \n",
    "    Parameters:\n",
    "    -----------\n",
    "    img_recon : reconstructed image\n",
    "    img_true : ground truth image\n",
    "    mask : binary mask\n",
    "    use_bbox : whether to use bounding box around ROI\n",
    "    \"\"\"\n",
    "    if np.sum(mask) == 0:\n",
    "        return np.nan\n",
    "    \n",
    "    if use_bbox:\n",
    "        # Find bounding box of tumor region\n",
    "        rows = np.any(mask, axis=1)\n",
    "        cols = np.any(mask, axis=0)\n",
    "        rmin, rmax = np.where(rows)[0][[0, -1]]\n",
    "        cmin, cmax = np.where(cols)[0][[0, -1]]\n",
    "        \n",
    "        # Extract bounding box regions\n",
    "        roi_recon = img_recon[rmin:rmax+1, cmin:cmax+1]\n",
    "        roi_true = img_true[rmin:rmax+1, cmin:cmax+1]\n",
    "        \n",
    "        # Check if ROI is large enough for SSIM\n",
    "        if roi_recon.shape[0] < 7 or roi_recon.shape[1] < 7:\n",
    "            return np.nan\n",
    "        \n",
    "        # Calculate SSIM on bounding box\n",
    "        return ssim(roi_true, roi_recon, data_range=1.0)\n",
    "    else:\n",
    "        # Masked SSIM (less reliable for small ROIs)\n",
    "        roi_recon = img_recon[mask > 0.5]\n",
    "        roi_true = img_true[mask > 0.5]\n",
    "        \n",
    "        if len(roi_recon) < 49:  # Less than 7x7\n",
