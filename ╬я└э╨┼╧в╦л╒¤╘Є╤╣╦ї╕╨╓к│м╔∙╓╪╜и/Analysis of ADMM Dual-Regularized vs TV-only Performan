    "\n",
    "# Step 7: Run reconstructions for all 30 images\n",
    "# This will take some time due to ADMM iterations\n",
    "\n",
    "results = []\n",
    "\n",
    "for idx, img_path in enumerate(selected_images):\n",
    "    print(f\"Processing image {idx+1}/30: {img_path.name}\")\n",
    "    \n",
    "    # Get mask path\n",
    "    mask_path = img_path.parent / img_path.name.replace('.png', '_mask.png')\n",
    "    if not mask_path.exists():\n",
    "        # Try alternative mask naming\n",
    "        mask_path = img_path.parent / img_path.name.replace('.png', '_mask_1.png')\n",
    "    \n",
    "    if not mask_path.exists():\n",
    "        print(f\"  Warning: Mask not found for {img_path.name}, skipping...\")\n",
    "        continue\n",
    "    \n",
    "    # Preprocess image and mask\n",
    "    img_true = preprocess_image(img_path, target_size)\n",
    "    mask = preprocess_mask(mask_path, target_size)\n",
    "    \n",
    "    # Create measurements\n",
    "    y = A @ img_true.flatten()\n",
    "    np.random.seed(43)  # Fixed seed for noise\n",
    "    y_noisy = add_noise_snr(y, target_snr_db=snr_db, seed=43)\n",
    "    \n",
    "    # Reconstruct with dual-regularized ADMM (TV + Wavelet)\n",
    "    print(f\"  Running dual ADMM...\")\n",
    "    img_recon_dual = admm_cs_reconstruction(\n",
    "        y_noisy, A, target_size, \n",
    "        lambda_tv=lambda_tv_dual, \n",
    "        lambda_wavelet=lambda_wavelet_dual,\n",
    "        rho=rho, max_iter=max_iter\n",
    "    )\n",
    "    \n",
    "    # Reconstruct with TV-only ADMM\n",
    "    print(f\"  Running TV-only ADMM...\")\n",
    "    img_recon_tv_only = admm_cs_reconstruction(\n",
    "        y_noisy, A, target_size,\n",
    "        lambda_tv=lambda_tv_only,\n",
    "        lambda_wavelet=0.0,  # No wavelet regularization\n",
    "        rho=rho, max_iter=max_iter\n",
    "    )\n",
    "    \n",
    "    # Calculate ROI SSIM for both methods\n",
    "    ssim_dual = calculate_roi_ssim(img_recon_dual, img_true, mask, use_bbox=True)\n",
    "    ssim_tv_only = calculate_roi_ssim(img_recon_tv_only, img_true, mask, use_bbox=True)\n",
    "    \n",
    "    # Calculate SSIM gain\n",
    "    ssim_gain = ssim_dual - ssim_tv_only\n",
    "    \n",
    "    # Calculate tumor area from original mask (not resized)\n",
    "    mask_original = io.imread(mask_path)\n",
    "    if len(mask_original.shape) == 3:\n",
    "        mask_original = np.mean(mask_original, axis=2)\n",
    "    tumor_area = np.sum(mask_original > 0.5 * mask_original.max())\n",
    "    \n",
    "    # Store results\n",
    "    results.append({\n",
    "        'image_name': img_path.name,\n",
    "        'class': img_path.parent.name,\n",
    "        'tumor_area': tumor_area,\n",
    "        'ssim_dual': ssim_dual,\n",
    "        'ssim_tv_only': ssim_tv_only,\n",
    "        'ssim_gain': ssim_gain\n",
    "    })\n",
    "    \n",
    "    print(f\"  Tumor area: {tumor_area:.0f} pixels\")\n",
    "    print(f\"  SSIM (Dual): {ssim_dual:.4f}, SSIM (TV-only): {ssim_tv_only:.4f}, Gain: {ssim_gain:.4f}\")\n",
    "    print()\n",
    "\n",
    "# Convert to DataFrame\n",
    "results_df = pd.DataFrame(results)\n",
    "print(\"Processing complete!\")\n",
    "print(f\"\\nResults shape: {results_df.shape}\")\n",
    "print(results_df.head(10))\n"
