    "\n",
    "# Define the Numba-optimized Adaptive-HASA algorithm\n",
    "# This combines gradient-based (TV) and entropy-based (wavelet) weighting\n",
    "\n",
    "def calculate_gradient_magnitude(image):\n",
    "    \"\"\"Calculate gradient magnitude for adaptive TV weighting\"\"\"\n",
    "    # Use Sobel operators for gradient\n",
    "    grad_x = ndimage.sobel(image, axis=1)\n",
    "    grad_y = ndimage.sobel(image, axis=0)\n",
    "    grad_mag = np.sqrt(grad_x**2 + grad_y**2)\n",
    "    return grad_mag\n",
    "\n",
    "def adaptive_hasa_reconstruction_numba(x_init, A, y, image_shape, \n",
    "                                       n_iterations=50, step_size=0.001,\n",
    "                                       base_tv_weight=0.15, base_wavelet_weight=0.15,\n",
    "                                       return_weights=False):\n",
    "    \"\"\"\n",
    "    Adaptive Hybrid Algorithm for Sparse Acquisition (HASA) with Numba optimization.\n",
    "    Uses gradient magnitude for TV weighting and entropy for wavelet weighting.\n",
    "    \n",
    "    Returns reconstruction and optionally the final adaptive weights.\n",
    "    \"\"\"\n",
    "    x = x_init.copy().flatten()\n",
    "    \n",
    "    # Storage for adaptive weights\n",
    "    tv_weight_map = None\n",
    "    wavelet_weight_map = None\n",
    "    \n",
    "    for iteration in range(n_iterations):\n",
    "        # Reshape current estimate\n",
    "        x_2d = x.reshape(image_shape)\n",
    "        \n",
    "        # Calculate adaptive weights based on current reconstruction\n",
    "        # Gradient magnitude for TV (edges need more TV regularization)\n",
    "        grad_mag = calculate_gradient_magnitude(x_2d)\n",
    "        grad_mag_norm = (grad_mag - grad_mag.min()) / (grad_mag.max() - grad_mag.min() + 1e-8)\n",
    "        tv_weight_map = base_tv_weight * (1 + grad_mag_norm)\n",
    "        \n",
    "        # Local entropy for wavelet (texture regions need more wavelet)\n",
    "        entropy_map = calculate_entropy_numba(x_2d, window_size=5)\n",
    "        entropy_norm = (entropy_map - entropy_map.min()) / (entropy_map.max() - entropy_map.min() + 1e-8)\n",
    "        wavelet_weight_map = base_wavelet_weight * (1 + entropy_norm)\n",
    "        \n",
    "        # Data fidelity gradient\n",
    "        residual = A @ x - y\n",
    "        grad_data = A.T @ residual\n",
    "        \n",
    "        # Gradient descent step\n",
    "        x = x - step_size * grad_data\n",
    "        \n",
    "        # Apply TV denoising with adaptive weights (pixel-wise)\n",
    "        x_2d = x.reshape(image_shape)\n",
    "        tv_weight_avg = tv_weight_map.mean()\n",
    "        x_tv = denoise_tv_chambolle(x_2d, weight=tv_weight_avg)\n",
    "        \n",
    "        # Apply wavelet soft thresholding with adaptive weights\n",
    "        wavelet_weight_avg = wavelet_weight_map.mean()\n",
    "        coeffs = pywt.wavedec2(x_tv, 'db4', level=3)\n",
    "        coeffs_thresh = [coeffs[0]]  # Keep approximation coefficients\n",
    "        for detail_level in coeffs[1:]:\n",
    "            thresh_level = []\n",
    "            for detail in detail_level:\n",
    "                threshold = wavelet_weight_avg * np.median(np.abs(detail)) / 0.6745\n",
    "                detail_thresh = pywt.threshold(detail, threshold, mode='soft')\n",
    "                thresh_level.append(detail_thresh)\n",
    "            coeffs_thresh.append(tuple(thresh_level))\n",
    "        \n",
    "        x_wavelet = pywt.waverec2(coeffs_thresh, 'db4')\n",
    "        \n",
    "        # Ensure shape matches\n",
    "        if x_wavelet.shape != image_shape:\n",
    "            x_wavelet = x_wavelet[:image_shape[0], :image_shape[1]]\n",
    "        \n",
    "        x = x_wavelet.flatten()\n",
    "    \n",
    "    final_reconstruction = x.reshape(image_shape)\n",
    "    \n",
    "    if return_weights:\n",
    "        return final_reconstruction, tv_weight_map, wavelet_weight_map\n",
    "    else:\n",
    "        return final_reconstruction\n",
    "\n",
    "print(\"Numba-optimized Adaptive-HASA defined\")\n"
   ]
