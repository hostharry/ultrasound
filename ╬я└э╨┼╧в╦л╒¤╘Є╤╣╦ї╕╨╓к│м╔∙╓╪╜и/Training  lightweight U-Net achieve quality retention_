    "\n",
    "# Define compressed sensing and reconstruction utilities\n",
    "# Following the previous analysis approach\n",
    "\n",
    "def preprocess_image(img_path, target_size=256):\n",
    "    \"\"\"Load and preprocess image for CS analysis\"\"\"\n",
    "    img = Image.open(img_path).convert('L')  # Convert to grayscale\n",
    "    img = img.resize((target_size, target_size), Image.BILINEAR)\n",
    "    img_array = np.array(img, dtype=np.float64) / 255.0  # Normalize to [0, 1]\n",
    "    return img_array\n",
    "\n",
    "def generate_measurement_matrix(n_measurements, n_pixels, seed=42):\n",
    "    \"\"\"Generate Gaussian random measurement matrix\"\"\"\n",
    "    np.random.seed(seed)\n",
    "    A = np.random.randn(n_measurements, n_pixels) / np.sqrt(n_measurements)\n",
    "    return A\n",
    "\n",
    "def add_noise_to_measurements(y_clean, target_snr_db=25, seed=43):\n",
    "    \"\"\"Add Gaussian noise to achieve target SNR\"\"\"\n",
    "    np.random.seed(seed)\n",
    "    signal_power = np.mean(y_clean ** 2)\n",
    "    snr_linear = 10 ** (target_snr_db / 10)\n",
    "    noise_power = signal_power / snr_linear\n",
    "    noise = np.sqrt(noise_power) * np.random.randn(len(y_clean))\n",
    "    y_noisy = y_clean + noise\n",
    "    return y_noisy\n",
    "\n",
    "def create_cs_measurements(image, sampling_rate=0.15, target_snr_db=25):\n",
    "    \"\"\"Create compressed sensing measurements from an image\"\"\"\n",
    "    n_pixels = image.size\n",
    "    n_measurements = int(sampling_rate * n_pixels)\n",
    "    \n",
    "    # Generate measurement matrix\n",
    "    A = generate_measurement_matrix(n_measurements, n_pixels, seed=42)\n",
    "    \n",
    "    # Flatten image and create clean measurements\n",
    "    x = image.flatten()\n",
    "    y_clean = A @ x\n",
    "    \n",
    "    # Add noise\n",
    "    y = add_noise_to_measurements(y_clean, target_snr_db, seed=43)\n",
    "    \n",
    "    return A, y\n",
    "\n",
    "def backproject(A, y, image_shape):\n",
    "    \"\"\"Simple backprojection reconstruction\"\"\"\n",
    "    x_bp = A.T @ y\n",
    "    return x_bp.reshape(image_shape)\n",
    "\n",
    "print(\"CS utilities defined successfully\")\n"
   ]
