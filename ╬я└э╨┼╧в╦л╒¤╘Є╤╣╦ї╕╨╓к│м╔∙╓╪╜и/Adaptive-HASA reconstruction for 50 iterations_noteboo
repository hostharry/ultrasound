    "\n",
    "# Generate compressed sensing measurement data at 15% sampling rate\n",
    "# Using fixed seeds for reproducibility (seed 42 for measurement matrix, seed 43 for noise)\n",
    "# Optimize by generating measurement matrix once since all images are same size\n",
    "\n",
    "def generate_cs_measurements(image, A, seed_noise=43):\n",
    "    \"\"\"\n",
    "    Generate compressed sensing measurements with Gaussian noise using pre-generated A matrix\n",
    "    \n",
    "    Parameters:\n",
    "    - image: 2D array, the original image\n",
    "    - A: measurement matrix\n",
    "    - seed_noise: random seed for noise generation\n",
    "    \n",
    "    Returns:\n",
    "    - y: measurement vector\n",
    "    \"\"\"\n",
    "    # Flatten image and take measurements\n",
    "    x = image.flatten()\n",
    "    y_clean = A @ x\n",
    "    \n",
    "    # Add Gaussian noise to achieve target SNR (25 dB)\n",
    "    np.random.seed(seed_noise)\n",
    "    signal_power = np.mean(y_clean ** 2)\n",
    "    noise_power = signal_power / (10 ** (25 / 10))\n",
    "    noise = np.sqrt(noise_power) * np.random.randn(len(y_clean))\n",
    "    y = y_clean + noise\n",
    "    \n",
    "    return y\n",
    "\n",
    "# Generate measurement matrix once (all images are 256x256)\n",
    "print(\"Generating measurement matrix...\")\n",
    "n = 256 * 256\n",
    "m = int(n * 0.15)\n",
    "np.random.seed(42)\n",
    "A = np.random.randn(m, n) / np.sqrt(m)\n",
    "print(f\"Measurement matrix shape: {A.shape}\")\n",
    "\n",
    "# Generate measurements for all 30 images\n",
    "measurements_data = []\n",
    "print(\"Generating compressed sensing measurements at 15% sampling rate with 25dB SNR...\")\n",
    "for i, img in enumerate(study_images):\n",
    "    y = generate_cs_measurements(img, A, seed_noise=43+i)\n",
    "    measurements_data.append({'y': y, 'A': A, 'image': img, 'mask': study_masks[i], 'label': study_labels[i]})\n",
    "    \n",
    "print(f\"Generated measurements for {len(measurements_data)} images\")\n",
    "print(f\"Measurement vector size: {measurements_data[0]['y'].shape}\")\n",
    "print(f\"Sampling rate: {m / n:.2%}\")\n"
   ]
