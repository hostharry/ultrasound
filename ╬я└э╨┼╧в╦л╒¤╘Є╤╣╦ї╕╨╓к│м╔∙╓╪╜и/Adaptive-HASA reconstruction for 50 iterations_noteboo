    "# Implement Adaptive-HASA reconstruction algorithm with configurable window size\n",
    "# This combines TV minimization with wavelet thresholding, using adaptive weights\n",
    "\n",
    "def calculate_local_gradient_variance(image, window_size):\n",
    "    \"\"\"Calculate local gradient variance using a sliding window\"\"\"\n",
    "    # Compute image gradients\n",
    "    gy, gx = np.gradient(image)\n",
    "    gradient_mag = np.sqrt(gx**2 + gy**2)\n",
    "    \n",
    "    # Calculate local variance of gradient magnitude\n",
    "    footprint = np.ones((window_size, window_size))\n",
    "    local_mean = ndimage.convolve(gradient_mag, footprint / footprint.sum(), mode='reflect')\n",
    "    local_sq_mean = ndimage.convolve(gradient_mag**2, footprint / footprint.sum(), mode='reflect')\n",
    "    local_var = np.maximum(local_sq_mean - local_mean**2, 0)\n",
    "    \n",
    "    return local_var\n",
    "\n",
    "def calculate_local_entropy(image, window_size):\n",
    "    \"\"\"Calculate local entropy using histogram-based approach (optimized)\"\"\"\n",
    "    from scipy.ndimage import uniform_filter\n",
    "    \n",
    "    # Quantize image to reduce computation\n",
    "    img_quantized = (image * 255).astype(np.uint8)\n",
    "    \n",
    "    # Use a faster approximation based on local standard deviation\n",
    "    # Entropy correlates with local variation\n",
    "    local_mean = uniform_filter(image, size=window_size, mode='reflect')\n",
    "    local_sq_mean = uniform_filter(image**2, size=window_size, mode='reflect')\n",
    "    local_std = np.sqrt(np.maximum(local_sq_mean - local_mean**2, 0))\n",
    "    \n",
    "    # Normalize to [0, 1] range as proxy for entropy\n",
    "    if local_std.max() > 0:\n",
    "        local_entropy_proxy = local_std / local_std.max()\n",
    "    else:\n",
    "        local_entropy_proxy = local_std\n",
    "    \n",
    "    return local_entropy_proxy\n",
    "\n",
